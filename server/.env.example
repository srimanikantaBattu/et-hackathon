

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/apex_capital

# ── Redis (Upstash cloud free tier) ──────────────────────────────
REDIS_URL=redis://default:your_redis_password@your-upstash-endpoint.upstash.io:6379

# ── Groq LLM ─────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Resend Email ─────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@
EMAIL_TO_PARTNERS=partners@

# ── App ───────────────────────────────────────────────────────────
DEBUG=true
FRONTEND_URL=http://localhost:3000
